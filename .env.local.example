# デイリーブリーフ 環境変数のひな型。
# これをコピーして .env.local を作り、Supabaseプロジェクトの値を入れると
# クラウド永続化(Supabase)が有効になる。未設定の間はlocalStorageで動く。
#
#   cp .env.local.example .env.local
#
# Vercelにデプロイする場合は、同じ2つを Vercel の Environment Variables に登録する。
# 値は Supabase ダッシュボード → Project Settings → API から取得できる。

# プロジェクトURL(例: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon public キー(公開してよいクライアント用キー。RLSで守る)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
