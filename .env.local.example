# デイリーブリーフ 環境変数のひな型。
# これをコピーして .env.local を作り、Supabaseプロジェクトの値を入れると
# クラウド永続化(Supabase)が有効になる。未設定の間はlocalStorageで動く。
#
#   cp .env.local.example .env.local
#
# Vercelにデプロイする場合は、同じ2つを Vercel の Environment Variables に登録する。
# 値は Supabase ダッシュボード → Project Settings → API から取得できる。

# プロジェクトURL(例: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon public キー(公開してよいクライアント用キー。RLSで守る)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- ブリーフ生成(実験ルート & 夜間Cron)。サーバー側だけが読む ----------
# Gemini APIキー(AI Studio。未設定なら生成は reason:"no_key" で静かに終わる)
GEMINI_API_KEY=
# 使うモデル(任意。既定は最安の gemini-flash-lite-latest)
GEMINI_MODEL=
# Jina Reader の APIキー(任意。無くてもキーレスで動く。高レートにしたい時だけ)
JINA_API_KEY=

# ---- 夜間Cron(/api/cron/build-brief)専用。フェーズ2 ----------------------
# GH Actions から叩く共有シークレット(GitHub Secrets の CRON_SECRET と一致させる)
CRON_SECRET=
# service_role キー(RLSをバイパスしてCronが本人の行を読み書きする。絶対に公開しない)
SUPABASE_SERVICE_ROLE_KEY=
# 本人の auth uuid(Supabase → Authentication → Users で確認)
OWNER_USER_ID=
# my-brain リポジトリ("owner/repo"。ここから taste/情報源を読む)
MYBRAIN_REPO=
# my-brain が private の場合の read トークン(contents:read。public なら省略可)
GITHUB_TOKEN=
# my-brain のブランチ(任意。既定 main)
MYBRAIN_REF=
